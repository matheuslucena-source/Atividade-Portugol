programa
{
    funcao inicio()
    {
        inteiro opcao = 2

        escolha (opcao)
        {
            caso 1:
                escreva("Novo Jogo")
                pare

            caso 2:
                escreva("Carregar Jogo")
                pare

            caso 3:
                escreva("Sair")
                pare

            caso contrario:
                escreva("Opcao invalida")
        }
    }
}