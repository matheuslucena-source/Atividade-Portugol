programa
{
    funcao inicio()
    {
        inteiro idade = 20
        real altura = 1.75
        cadeia nome = "Ana"
        logico trabalha = verdadeiro

        escreva("Idade: ", idade, "\n")
        escreva("Altura: ", altura, "\n")
        escreva("Nome: ", nome, "\n")
        escreva("Trabalha: ", trabalha)
    }
}