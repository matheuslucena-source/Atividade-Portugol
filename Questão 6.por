programa
{
    funcao inicio()
    {
        inteiro idade = 21
        real altura = 1.68
        cadeia nome = "Matheus"
        caracter sexo = 'M'
        logico trabalha = verdadeiro

        escreva("Nome: ", nome, "\n")
